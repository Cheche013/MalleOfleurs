<ul>
  <% if admin_signed_in? %>
    <li>
      <%= link_to "Sign out", destroy_admin_session_path, data: {turbo_method: :delete} %>
    </li>

    <li>
      Voici ton email : <%= current_admin.email %>
    </li>

    <li>
      <%= link_to "Edit email / password", edit_admin_registration_path %>
    </li>

  <% else %>
    <li>    
      <%= link_to "Sign in", new_admin_session_path %>
    </li>

    <li>
      <%= link_to "Sign up", new_admin_registration_path %>
    </li>

  <% end %>
</ul>